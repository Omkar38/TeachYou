# Local dev token (used by API auth + frontend)
DEV_TOKEN=dev-token

# Database (optional locally; docker-compose uses Postgres via POSTGRES_DSN)
# DATABASE_DSN=sqlite:///./data/app.db
# POSTGRES_DSN=postgresql+psycopg2://genai:genai@localhost:5432/genai

# Postgres runtime variables used by docker-compose (don't commit real secrets to `.env`)
POSTGRES_USER=genai
POSTGRES_PASSWORD=
POSTGRES_DB=genai

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# OpenAI (LLM + TTS)
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin

# Google Cloud TTS (fallback)
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service_account.json

# TTS fallback order
TTS_PROVIDER_ORDER=openai,google,espeak

# Output data directory
DATA_DIR=./data