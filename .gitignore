# data/

# Node / Next.js / JS builds
node_modules/
**/node_modules/
.next/
out/
dist/
build/

# IDEs / editors
.vscode/
.idea/

# Logs / temp
*.log
tmp/
*.tmp

# Database / local data files
*.sqlite3
*.db