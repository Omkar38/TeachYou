FROM node:20-alpine AS build

WORKDIR /app

# Build-time public API base (inlined by Next for client bundles)
ARG NEXT_PUBLIC_API_BASE=http://localhost:8000
ENV NEXT_PUBLIC_API_BASE=$NEXT_PUBLIC_API_BASE

COPY frontend/package.json ./package.json
RUN npm install

COPY frontend .
RUN npm run build

FROM node:20-alpine
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=5173

COPY --from=build /app .

EXPOSE 5173
CMD ["npm", "run", "start"]
