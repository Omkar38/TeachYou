{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/health(.*)", "dest": "/api/index.py" },
    { "src": "/documents(.*)", "dest": "/api/index.py" },
    { "src": "/jobs(.*)", "dest": "/api/index.py" },
    { "src": "/assets(.*)", "dest": "/api/index.py" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
